{
  "manifest_version": 3,
  "name": "Civil Service Jobs → Sheffield Digital",
  "version": "1.1",
  "description": "Extract Civil Service job listings and post them to the Sheffield Digital job board.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.civilservicejobs.service.gov.uk/*",
    "https://sheffield.digital/*"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Post to Sheffield Digital",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  }
}
